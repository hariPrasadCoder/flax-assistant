# ── Backend ───────────────────────────────────────────────────
# For local dev, defaults to localhost. For packaged builds, set to your deployed URL.
BACKEND_URL=http://localhost:8747
WS_URL=ws://localhost:8747/ws/mascot

# ── Supabase (required for OTP login) ─────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Project Settings → API → anon/public key (safe to include in client)
SUPABASE_ANON_KEY=your-anon-key
