# ── Supabase ──────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Project Settings → API → service_role key (backend only — keep this secret!)
SUPABASE_KEY=your-service-role-key
# Note: SUPABASE_ANON_KEY is used by the desktop app (not the backend).
# Set it as a GitHub Actions secret for the desktop build workflow.

# ── Core ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Observability (optional but recommended) ──────────────────
# Sentry — get DSN from sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# Langfuse — LLM call tracing, get keys from cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
# For production, set to your frontend origin:
# CORS_ORIGINS=https://your-app.com
CORS_ORIGINS=*

# ── Google Calendar (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
